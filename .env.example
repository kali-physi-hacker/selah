# ── Optional authentication & cloud-synced profile ──────────────────────────
# Selah runs fully WITHOUT any of these (progress/bookmarks stay in localStorage).
# Set all of the below to turn ON optional Google sign-in + cross-device sync.
# Copy to `.env.local` for local dev; set the same vars in Vercel for production.

# Master switch. Until this is exactly "true", there are no auth code paths at all.
# NOTE: it's build-time inlined — changing it requires a redeploy/rebuild.
NEXT_PUBLIC_AUTH_ENABLED=

# Auth.js (NextAuth) session-signing secret.  Generate: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth client — Google Cloud Console → APIs & Services → Credentials →
#   Create Credentials → OAuth client ID → Web application.
# Authorized redirect URIs:
#   https://<your-domain>/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Postgres connection string (the profile store).
# Auto-added by the Vercel "Neon" Marketplace integration (Storage → Create Database).
DATABASE_URL=

# Admin allowlist for the /admin analytics dashboard — comma-separated emails of
# signed-in Google accounts allowed in. Defaults to the owner if unset.
ADMIN_EMAILS=
